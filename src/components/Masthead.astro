---
type NavKey = 'home' | 'courses' | 'faculty' | 'alumni' | null;
interface Props {
  activeNav?: NavKey;
}
const { activeNav = null } = Astro.props;

// locals are populated by middleware on SSR routes; undefined on static routes.
const user = Astro.locals?.user ?? null;
const profile = Astro.locals?.profile ?? null;
const role = profile?.role ?? null;
const displayName = profile?.character_name || user?.email?.split('@')[0] || null;
---

<header class="masthead">
  <div class="masthead-inner">
    <a class="crest" href="/">
      <svg class="crest-mark" viewBox="0 0 100 100" aria-hidden="true">
        <path d="M50 6 L88 16 L88 46 C88 66 72 84 50 94 C28 84 12 66 12 46 L12 16 Z" fill="#1f3a2e" stroke="#a8843a" stroke-width="2"></path>
        <path d="M50 11 L84 20 L84 46 C84 64 70 80 50 89 C30 80 16 64 16 46 L16 20 Z" stroke="#a8843a" fill="none" stroke-width="0.8" opacity="0.6"></path>
        <g fill="#c9a14e" stroke="none">
          <ellipse cx="42" cy="60" rx="6" ry="5" transform="rotate(-20 42 60)"></ellipse>
          <rect x="46" y="34" width="2" height="22"></rect>
          <path d="M48 34 Q 58 36 58 46 Q 56 40 48 40 Z"></path>
          <ellipse cx="62" cy="64" rx="6" ry="5" transform="rotate(-20 62 64)"></ellipse>
          <rect x="66" y="38" width="2" height="22"></rect>
        </g>
        <path d="M48 34 L66 38" stroke="#c9a14e" stroke-width="2" fill="none"></path>
      </svg>
      <div class="crest-text">
        <span class="crest-name">OLD TOBY ACADEMY</span>
        <span class="crest-sub">— a school of music for the realm —</span>
      </div>
    </a>
    <nav class="nav">
      <a href="/" class:list={[{ active: activeNav === 'home' }]}>Home</a>
      <a href="/courses" class:list={[{ active: activeNav === 'courses' }]}>Courses</a>
      <a href="/faculty" class:list={[{ active: activeNav === 'faculty' }]}>Faculty</a>
      <a href="/alumni" class:list={[{ active: activeNav === 'alumni' }]}>Alumni Hall</a>
      {role === 'headmaster' && <a href="/admin">Admin</a>}
      {user ? (
        <span class="user-pill" data-role={role ?? 'student'}>
          {displayName}<span class="user-role">· {role ?? '—'}</span>
        </span>
        <form method="POST" action="/api/logout" class="logout-form">
          <button type="submit" class="logout-btn" title="Sign out">Sign out</button>
        </form>
      ) : (
        <a href="/login" class="nav-signin">Sign in</a>
      )}
    </nav>
  </div>
</header>

<style is:global>
  .nav .user-pill {
    color: var(--forest-deep);
    border-bottom: none;
    font-family: var(--body);
    font-style: italic;
    text-transform: none;
    letter-spacing: 0;
    padding-left: 12px;
    border-left: 1px solid var(--rule-soft);
  }
  .nav .user-pill[data-role="faculty"] { color: #8a6e1d; }
  .nav .user-pill[data-role="headmaster"] { color: var(--oxblood); font-weight: 600; }
  .nav .user-role {
    margin-left: 6px;
    font-size: 0.78rem;
    color: var(--ink-soft);
  }

  .nav .logout-form { display: inline; }
  .nav .logout-btn {
    background: transparent;
    border: none;
    border-bottom: 1px solid transparent;
    color: var(--ink-soft);
    font-family: var(--display);
    font-size: 1.05rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0 0 2px;
    cursor: pointer;
  }
  .nav .logout-btn:hover {
    color: var(--oxblood);
    border-bottom-color: var(--gold);
  }

  .nav .nav-signin {
    color: var(--oxblood);
    border-bottom-color: var(--gold);
  }
</style>
