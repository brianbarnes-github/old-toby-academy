---
import BaseLayout from '../layouts/BaseLayout.astro';

export const prerender = false;

const error = Astro.url.searchParams.get('error');
const name = Astro.url.searchParams.get('name') ?? '';
const next = Astro.url.searchParams.get('next') ?? '/courses';
---

<BaseLayout
  title="Sign In · Old Toby Academy"
  description="Sign in to the academy."
  footerVariant="short"
>
  <main class="page">
    <div class="auth-wrap">
      <div class="eyebrow">Members' Entrance</div>
      <h1>Sign in to the Hall</h1>
      <p class="kicker">Use the character name and password from when your token was redeemed. New members redeem a token at <a href="/signup">the signup page</a>.</p>

      {error && <div class="auth-err">{error}</div>}

      <form class="auth-form" method="POST" action="/api/login">
        <input type="hidden" name="next" value={next} />
        <input type="hidden" name="variant" value="student" />
        <label>Character name<input type="text" name="name" required value={name} autocomplete="username" placeholder="e.g. Vydor" /></label>
        <label>Password<input type="password" name="password" required autocomplete="current-password" /></label>
        <button class="btn" type="submit">Sign in</button>
      </form>

      <p class="auth-aside">
        Faculty? Use the <a href="/faculty-login">faculty entrance</a>.
      </p>
    </div>
  </main>
</BaseLayout>

<style is:global>
  .auth-wrap {
    max-width: 520px;
    margin: 80px auto;
    padding: 56px 40px;
    background: linear-gradient(180deg, rgba(255,250,235,0.6), rgba(217,195,136,0.18));
    border: 1px solid var(--rule);
    box-shadow: 0 0 0 6px var(--parchment), 0 0 0 7px var(--rule-soft);
  }
  .auth-wrap h1 {
    font-style: italic; font-weight: 500;
    font-size: clamp(2rem, 4vw, 2.6rem); margin-bottom: 8px;
  }
  .auth-wrap .kicker { margin-bottom: 28px; }

  .auth-form { display: flex; flex-direction: column; gap: 16px; margin-top: 8px; }
  .auth-form label {
    display: flex; flex-direction: column; gap: 4px;
    font-family: var(--display); font-size: 0.85rem;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--ink-soft);
  }
  .auth-form input {
    font-family: var(--body); font-size: 1rem;
    padding: 10px 12px;
    background: rgba(255, 250, 235, 0.7);
    border: 1px solid var(--rule-soft); border-radius: 2px;
    color: var(--ink); letter-spacing: 0; text-transform: none;
  }
  .auth-form input:focus {
    outline: none; border-color: var(--gold); background: rgba(255, 250, 235, 0.95);
  }
  .auth-form button { align-self: flex-start; margin-top: 8px; }

  .auth-err {
    background: rgba(107, 31, 26, 0.08);
    border-left: 3px solid var(--oxblood);
    color: var(--oxblood-deep);
    padding: 12px 16px; margin: 0 0 20px;
    font-size: 0.95rem; font-style: italic;
  }

  .auth-aside {
    margin-top: 24px;
    padding-top: 20px;
    border-top: 1px solid var(--rule-soft);
    font-size: 0.92rem; font-style: italic;
    color: var(--ink-soft);
  }
</style>
