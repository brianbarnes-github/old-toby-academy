---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import {
  renderMarkdown,
  containsTasks,
  containsQuizShortcodes,
  replaceQuizShortcodes,
} from '../../../../lib/markdown';

export const prerender = false;

const supabase = Astro.locals.supabase;
const { courseSlug, classSlug } = Astro.params;

if (!courseSlug || !classSlug) return Astro.redirect('/courses');

const { data: course } = await supabase
  .from('courses')
  .select('*')
  .eq('slug', courseSlug)
  .maybeSingle();

if (!course) return Astro.redirect('/courses?error=' + encodeURIComponent('Course not found.'));

const { data: cls } = await supabase
  .from('classes')
  .select('*')
  .eq('course_id', course.id)
  .eq('slug', classSlug)
  .maybeSingle();

if (!cls) {
  return Astro.redirect(`/courses/${courseSlug}?error=` + encodeURIComponent('Class not found.'));
}

const userId = Astro.locals.user?.id;
const isAuthor = userId !== undefined && cls.created_by === userId;
const isHeadmaster = Astro.locals.profile?.role === 'headmaster';
const canManage = isAuthor || isHeadmaster;

// Sequential gate: students can't reach a locked class even if they
// type the URL. RLS handles the draft case (published_at null).
if (course.order_mode === 'sequential' && !canManage) {
  const { data: prevClasses } = await supabase
    .from('classes')
    .select('id, slug, order_index, closed_at, published_at')
    .eq('course_id', course.id)
    .order('order_index');

  const all = prevClasses ?? [];
  const idx = all.findIndex((c: any) => c.slug === cls.slug);
  if (idx > 0) {
    const prev = all[idx - 1] as any;
    if (prev.closed_at === null) {
      return Astro.redirect(
        `/courses/${courseSlug}?error=` +
          encodeURIComponent('That class is locked. Wait for the previous one to be marked complete.')
      );
    }
  }
}

// Find adjacent classes for prev/next nav (only among published).
const { data: siblings } = await supabase
  .from('classes')
  .select('slug, title, order_index, published_at, closed_at')
  .eq('course_id', course.id)
  .order('order_index');

const all = siblings ?? [];
const here = all.findIndex((c: any) => c.slug === cls.slug);
const prevClass = here > 0 ? all[here - 1] : null;
const nextClass = here >= 0 && here < all.length - 1 ? all[here + 1] : null;

// Hide nav links to locked/draft neighbors for students.
const showPrev = prevClass && (canManage || (
  (prevClass as any).published_at !== null
  && (course.order_mode !== 'sequential' || here - 2 < 0 || (all[here - 2] as any)?.closed_at !== null)
));
const showNext = nextClass && (canManage || (
  (nextClass as any).published_at !== null
  && (course.order_mode !== 'sequential' || (cls as any).closed_at !== null)
));

const bodyHtml = renderMarkdown(cls.body_md ?? '');
const hasTasks = containsTasks(bodyHtml);

// Hydrate per-user task state for this class.
const taskState: Record<string, boolean> = {};
if (hasTasks && userId) {
  const { data: marks } = await supabase
    .from('progress_marks')
    .select('mark_key, value')
    .eq('user_id', userId)
    .eq('course_slug', courseSlug)
    .eq('mark_type', 'exercise')
    .like('mark_key', `${cls.id}:task-%`);

  for (const m of marks ?? []) {
    const colon = (m.mark_key as string).indexOf(':');
    if (colon < 0) continue;
    const taskKey = (m.mark_key as string).slice(colon + 1);
    if ((m.value as any)?.completed === true) {
      taskState[taskKey] = true;
    }
  }
}

// Class attachments — files that aren't referenced inline render as a downloads list.
const { data: attachments } = await supabase
  .from('class_attachments')
  .select('id, kind, file_path, file_name, file_size, content_type, caption, created_at')
  .eq('class_id', cls.id)
  .order('created_at', { ascending: true });

function attachUrl(path: string): string {
  return supabase.storage.from('class-files').getPublicUrl(path).data.publicUrl;
}

function fmtBytes(bytes: number | null): string {
  if (!bytes) return '';
  if (bytes < 1024) return `${bytes} B`;
  if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`;
  return `${(bytes / (1024 * 1024)).toFixed(1)} MB`;
}

const inlineRefs = new Set<string>();
for (const a of attachments ?? []) {
  const url = attachUrl(a.file_path);
  if ((cls.body_md ?? '').includes(url)) inlineRefs.add(a.id);
}
const downloadAttachments = (attachments ?? []).filter((a: any) => !inlineRefs.has(a.id));

// ---------- Quizzes ----------
const hasQuizShortcodes = containsQuizShortcodes(bodyHtml);
let bodyWithQuizzes = bodyHtml;
const quizState: Record<string, { option_id: string; correct: boolean }> = {};
let hasAnyQuiz = false;

if (hasQuizShortcodes) {
  const { data: quizzes } = await supabase
    .from('class_quizzes')
    .select(`
      id, slug, title, intro_md, order_index,
      class_quiz_questions (
        id, prompt_md, explanation_md, order_index,
        class_quiz_options ( id, label, is_correct, order_index )
      )
    `)
    .eq('class_id', cls.id)
    .order('order_index', { ascending: true });

  const bySlug = new Map<string, any>();
  for (const q of quizzes ?? []) {
    bySlug.set(q.slug as string, q);
  }

  // Pre-fetch the user's prior answers for this class's quizzes.
  if (userId && (quizzes ?? []).length > 0) {
    const { data: marks } = await supabase
      .from('progress_marks')
      .select('mark_key, value')
      .eq('user_id', userId)
      .eq('course_slug', courseSlug)
      .eq('mark_type', 'quiz')
      .like('mark_key', `${cls.id}:%`);
    for (const m of marks ?? []) {
      const colon = (m.mark_key as string).indexOf(':');
      if (colon < 0) continue;
      const questionId = (m.mark_key as string).slice(colon + 1);
      const v = m.value as any;
      if (v && typeof v.option_id === 'string') {
        quizState[questionId] = { option_id: v.option_id, correct: v.correct === true };
      }
    }
  }

  function escapeHtml(s: string): string {
    return s
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function renderQuiz(slug: string): string {
    const quiz = bySlug.get(slug);
    if (!quiz) {
      return `<aside class="quiz-missing">Quiz <code>${escapeHtml(slug)}</code> not found.</aside>`;
    }
    const introHtml = quiz.intro_md ? renderMarkdown(quiz.intro_md) : '';
    const questions = (quiz.class_quiz_questions ?? [])
      .slice()
      .sort((a: any, b: any) => (a.order_index ?? 0) - (b.order_index ?? 0));

    const questionsHtml = questions
      .map((q: any) => {
        if (!q || !Array.isArray(q.class_quiz_options) || q.class_quiz_options.length === 0) {
          return '';
        }
        hasAnyQuiz = true;
        const promptHtml = renderMarkdown(q.prompt_md ?? '');
        const explHtml = q.explanation_md ? renderMarkdown(q.explanation_md) : '';
        const options = q.class_quiz_options
          .slice()
          .sort((a: any, b: any) => (a.order_index ?? 0) - (b.order_index ?? 0));
        const optsHtml = options
          .map(
            (o: any) => `
            <li class="quiz-opt">
              <label>
                <input type="radio" name="q-${q.id}" value="${escapeHtml(o.id)}" />
                <span>${escapeHtml(o.label ?? '')}</span>
              </label>
            </li>`,
          )
          .join('');
        return `
          <form class="quiz-q" data-question-id="${escapeHtml(q.id)}">
            <div class="quiz-prompt">${promptHtml}</div>
            <ol class="quiz-options">${optsHtml}</ol>
            <div class="quiz-actions">
              <button class="btn btn-ghost btn-sm" type="submit">Submit answer</button>
            </div>
            ${explHtml ? `<div class="quiz-explanation" hidden>${explHtml}</div>` : ''}
          </form>`;
      })
      .join('');

    return `
      <section class="quiz-block" data-quiz-slug="${escapeHtml(quiz.slug)}">
        <h3 class="quiz-title">${escapeHtml(quiz.title ?? '')}</h3>
        ${introHtml ? `<div class="quiz-intro">${introHtml}</div>` : ''}
        ${questionsHtml || '<p class="muted italic">No questions yet.</p>'}
      </section>`;
  }

  bodyWithQuizzes = replaceQuizShortcodes(bodyHtml, renderQuiz);
}
---

<BaseLayout
  title={`${cls.title} · ${course.title}`}
  description={cls.summary ?? undefined}
  activeNav="courses"
  footerVariant="short"
>
  <main class="page">
    <div class="crumbs">
      <a href="/courses">Courses</a><span>›</span>
      <a href={`/courses/${course.slug}`}>{course.title}</a><span>›</span>
      <em>{cls.title}</em>
    </div>

    <article class="class-reader">
      <div class="page-head">
        <div class="eyebrow">{course.title} · Class {(cls.order_index ?? 0) + 1}</div>
        <h1>
          {cls.title}
          {cls.published_at === null && <span class="course-status-chip course-status-draft" style="margin-left: 12px; font-size: 0.5em;">draft</span>}
          {cls.closed_at !== null && <span class="course-status-chip course-status-published" style="margin-left: 12px; font-size: 0.5em;">complete</span>}
        </h1>
        {cls.summary && <p class="kicker">{cls.summary}</p>}
        {canManage && (
          <p style="margin-top: 16px;">
            <a class="btn btn-ghost" href={`/courses/${course.slug}/${cls.slug}/edit`}>Edit class</a>
          </p>
        )}
      </div>

      {bodyHtml ? (
        <div
          class="class-body"
          data-class-id={cls.id}
          data-course-slug={course.slug}
          set:html={bodyWithQuizzes}
        />
      ) : (
        <p class="muted italic">No content yet.{canManage && <> <a href={`/courses/${course.slug}/${cls.slug}/edit`}>Add some</a>.</>}</p>
      )}

      {hasTasks && (
        <script
          type="application/json"
          id="task-state"
          set:html={JSON.stringify(taskState).replace(/</g, '\\u003c')}
        />
      )}
      {hasTasks && <script src="/scripts/class-tasks.js" defer></script>}

      {hasAnyQuiz && (
        <script
          type="application/json"
          id="quiz-state"
          set:html={JSON.stringify(quizState).replace(/</g, '\\u003c')}
        />
      )}
      {hasAnyQuiz && <script src="/scripts/class-quiz.js" defer></script>}

      {downloadAttachments.length > 0 && (
        <section class="class-downloads">
          <h2>Files</h2>
          <ul class="class-downloads-list">
            {downloadAttachments.map((a: any) => (
              <li>
                <a href={attachUrl(a.file_path)} target="_blank" rel="noopener noreferrer" download={a.file_name}>
                  {a.caption ?? a.file_name}
                </a>
                <span class="class-download-meta">{a.file_name} · {fmtBytes(a.file_size)}</span>
              </li>
            ))}
          </ul>
        </section>
      )}

      <nav class="lesson-nav" style="margin-top: 64px;">
        {showPrev ? (
          <a href={`/courses/${course.slug}/${(prevClass as any).slug}`} class="prev">
            <span class="nav-label">← Previous</span>
            <span class="nav-title">{(prevClass as any).title}</span>
          </a>
        ) : (
          <a href={`/courses/${course.slug}`} class="prev">
            <span class="nav-label">← Back</span>
            <span class="nav-title">Course overview</span>
          </a>
        )}
        {showNext ? (
          <a href={`/courses/${course.slug}/${(nextClass as any).slug}`} class="next">
            <span class="nav-label">Next →</span>
            <span class="nav-title">{(nextClass as any).title}</span>
          </a>
        ) : (
          <a href={`/courses/${course.slug}`} class="next">
            <span class="nav-label">Course overview →</span>
            <span class="nav-title">{course.title}</span>
          </a>
        )}
      </nav>
    </article>
  </main>
</BaseLayout>

<style is:global>
  .class-reader { max-width: 760px; margin: 0 auto; }
  .class-body { margin: 32px 0; line-height: 1.7; }
  .class-body h1 { font-style: italic; font-weight: 500; margin-top: 32px; }
  .class-body h2 { font-style: italic; font-weight: 500; margin-top: 28px; font-size: 1.6rem; }
  .class-body h3 { font-weight: 500; margin-top: 24px; font-size: 1.3rem; }
  .class-body p { margin-bottom: 1em; }
  .class-body ul, .class-body ol { margin: 1em 0; padding-left: 24px; }
  .class-body li { margin-bottom: 0.4em; }
  .class-body code {
    background: rgba(168, 132, 58, 0.18);
    padding: 1px 6px; border-radius: 2px;
    font-family: var(--mono);
  }
  .class-body pre {
    background: var(--ink); color: #ddd0a8;
    padding: 18px 22px; border-left: 3px solid var(--gold);
    overflow-x: auto;
    margin: 16px 0;
  }
  .class-body pre code { background: none; padding: 0; }
  .class-body blockquote {
    border-left: 3px solid var(--gold);
    padding-left: 16px; font-style: italic; color: var(--ink-soft);
    margin: 16px 0;
  }
  .class-body img { max-width: 100%; height: auto; }
  .class-body table { width: 100%; border-collapse: collapse; margin: 16px 0; }
  .class-body th, .class-body td { padding: 10px 14px; border-bottom: 1px solid var(--rule-soft); }
  .class-body th { font-family: var(--display); text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.85rem; }

  /* Interactive task checkboxes (GFM task lists) */
  .class-body ul:has(> li.task-li) {
    list-style: none;
    padding-left: 0;
  }
  .class-body li.task-li {
    list-style: none;
    margin-left: 0;
    padding: 4px 0 4px 4px;
    transition: background-color 0.4s ease, color 0.2s ease;
  }
  .class-body li.task-li input[type="checkbox"] {
    appearance: none;
    -webkit-appearance: none;
    width: 18px;
    height: 18px;
    margin-right: 10px;
    border: 1.5px solid var(--ink-soft);
    background: var(--parchment);
    cursor: pointer;
    vertical-align: -3px;
    position: relative;
  }
  .class-body li.task-li input[type="checkbox"]:checked {
    background: var(--gold);
    border-color: var(--gold);
  }
  .class-body li.task-li input[type="checkbox"]:checked::after {
    content: "";
    position: absolute;
    left: 4px;
    top: 0px;
    width: 5px;
    height: 10px;
    border: solid var(--ink);
    border-width: 0 2px 2px 0;
    transform: rotate(45deg);
  }
  .class-body li.task-li input[type="checkbox"]:focus-visible {
    outline: 2px solid var(--oxblood);
    outline-offset: 2px;
  }
  .class-body li.task-li.is-done {
    color: var(--ink-soft);
    text-decoration: line-through;
  }
  .class-body li.task-li.is-saved {
    background: rgba(168, 132, 58, 0.18);
  }
  .class-body li.task-li.is-error {
    background: rgba(107, 31, 26, 0.14);
  }

  /* Downloads / file attachments */
  .class-downloads {
    margin-top: 56px;
    padding-top: 24px;
    border-top: 1px double var(--rule-soft);
  }
  .class-downloads h2 {
    font-style: italic;
    font-weight: 500;
    margin-bottom: 12px;
    font-size: 1.4rem;
  }
  .class-downloads-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .class-downloads-list li {
    padding: 10px 14px;
    border: 1px solid var(--rule-soft);
    background: rgba(255, 250, 235, 0.55);
    display: flex;
    align-items: baseline;
    gap: 12px;
    flex-wrap: wrap;
  }
  .class-downloads-list a {
    font-family: var(--display);
    font-weight: 600;
    color: var(--forest-deep);
    border-bottom: none;
  }
  .class-downloads-list a:hover { color: var(--oxblood); }
  .class-download-meta {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--ink-soft);
    letter-spacing: 0.04em;
  }

  /* Quizzes */
  .class-body .quiz-block {
    margin: 36px 0;
    padding: 24px 28px;
    background: rgba(255, 250, 235, 0.55);
    border: 1px solid var(--rule-soft);
    border-left: 4px solid var(--gold);
  }
  .class-body .quiz-title {
    margin: 0 0 12px;
    font-style: italic;
    font-weight: 500;
    font-size: 1.4rem;
    color: var(--forest-deep);
  }
  .class-body .quiz-intro {
    color: var(--ink-soft);
    margin-bottom: 18px;
  }
  .class-body .quiz-q {
    margin: 22px 0 0;
    padding-top: 18px;
    border-top: 1px dashed var(--rule-soft);
  }
  .class-body .quiz-q:first-of-type {
    border-top: none;
    padding-top: 0;
  }
  .class-body .quiz-prompt {
    font-family: var(--display);
    font-weight: 600;
    color: var(--forest-deep);
    margin-bottom: 12px;
  }
  .class-body .quiz-prompt p { margin-bottom: 0; }
  .class-body .quiz-options {
    list-style: none;
    padding-left: 0;
    margin: 0 0 12px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .class-body .quiz-opt label {
    display: flex;
    align-items: baseline;
    gap: 10px;
    padding: 6px 10px;
    border: 1px solid transparent;
    cursor: pointer;
    transition: background-color 0.15s, border-color 0.15s;
  }
  .class-body .quiz-opt label:hover {
    background: rgba(168, 132, 58, 0.1);
  }
  .class-body .quiz-opt input[type="radio"] {
    accent-color: var(--gold);
    margin: 0;
  }
  .class-body .quiz-opt.opt-correct label {
    background: rgba(70, 105, 40, 0.15);
    border-color: #466928;
    color: #2c4218;
  }
  .class-body .quiz-opt.opt-correct label::after {
    content: "✓";
    margin-left: auto;
    color: #466928;
    font-weight: 700;
  }
  .class-body .quiz-opt.opt-wrong label {
    background: rgba(107, 31, 26, 0.12);
    border-color: var(--oxblood);
    color: var(--oxblood-deep);
  }
  .class-body .quiz-opt.opt-wrong label::after {
    content: "✗";
    margin-left: auto;
    color: var(--oxblood);
    font-weight: 700;
  }
  .class-body .quiz-actions {
    display: flex;
    gap: 12px;
    align-items: center;
  }
  .class-body .quiz-q.is-answered .quiz-actions button {
    background: rgba(255, 250, 235, 0.5);
  }
  .class-body .quiz-explanation {
    margin-top: 14px;
    padding: 12px 16px;
    background: rgba(31, 58, 46, 0.05);
    border-left: 3px solid var(--forest);
    color: var(--ink-soft);
    font-size: 0.95rem;
  }
  .class-body .quiz-explanation p:last-child { margin-bottom: 0; }
  .class-body .quiz-hint {
    display: inline-block;
    margin-left: 12px;
    color: var(--oxblood);
    font-style: italic;
    font-size: 0.9rem;
  }
  .class-body .quiz-missing {
    margin: 24px 0;
    padding: 12px 16px;
    background: rgba(107, 31, 26, 0.08);
    border-left: 3px solid var(--oxblood);
    color: var(--oxblood-deep);
    font-style: italic;
    font-size: 0.95rem;
  }
</style>
