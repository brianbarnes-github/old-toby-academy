---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { renderMarkdown } from '../../../../lib/markdown';

export const prerender = false;

const supabase = Astro.locals.supabase;
const { courseSlug, classSlug } = Astro.params;

if (!courseSlug || !classSlug) return Astro.redirect('/courses');

const { data: course } = await supabase
  .from('courses')
  .select('*')
  .eq('slug', courseSlug)
  .maybeSingle();

if (!course) return Astro.redirect('/courses?error=' + encodeURIComponent('Course not found.'));

const { data: cls } = await supabase
  .from('classes')
  .select('*')
  .eq('course_id', course.id)
  .eq('slug', classSlug)
  .maybeSingle();

if (!cls) {
  return Astro.redirect(`/courses/${courseSlug}?error=` + encodeURIComponent('Class not found.'));
}

const userId = Astro.locals.user?.id;
const isAuthor = userId !== undefined && cls.created_by === userId;
const isHeadmaster = Astro.locals.profile?.role === 'headmaster';
const canManage = isAuthor || isHeadmaster;

// Sequential gate: students can't reach a locked class even if they
// type the URL. RLS handles the draft case (published_at null).
if (course.order_mode === 'sequential' && !canManage) {
  const { data: prevClasses } = await supabase
    .from('classes')
    .select('id, slug, order_index, closed_at, published_at')
    .eq('course_id', course.id)
    .order('order_index');

  const all = prevClasses ?? [];
  const idx = all.findIndex((c: any) => c.slug === cls.slug);
  if (idx > 0) {
    const prev = all[idx - 1] as any;
    if (prev.closed_at === null) {
      return Astro.redirect(
        `/courses/${courseSlug}?error=` +
          encodeURIComponent('That class is locked. Wait for the previous one to be marked complete.')
      );
    }
  }
}

// Find adjacent classes for prev/next nav (only among published).
const { data: siblings } = await supabase
  .from('classes')
  .select('slug, title, order_index, published_at, closed_at')
  .eq('course_id', course.id)
  .order('order_index');

const all = siblings ?? [];
const here = all.findIndex((c: any) => c.slug === cls.slug);
const prevClass = here > 0 ? all[here - 1] : null;
const nextClass = here >= 0 && here < all.length - 1 ? all[here + 1] : null;

// Hide nav links to locked/draft neighbors for students.
const showPrev = prevClass && (canManage || (
  (prevClass as any).published_at !== null
  && (course.order_mode !== 'sequential' || here - 2 < 0 || (all[here - 2] as any)?.closed_at !== null)
));
const showNext = nextClass && (canManage || (
  (nextClass as any).published_at !== null
  && (course.order_mode !== 'sequential' || (cls as any).closed_at !== null)
));

const bodyHtml = renderMarkdown(cls.body_md ?? '');
---

<BaseLayout
  title={`${cls.title} · ${course.title}`}
  description={cls.summary ?? undefined}
  activeNav="courses"
  footerVariant="short"
>
  <main class="page">
    <div class="crumbs">
      <a href="/courses">Courses</a><span>›</span>
      <a href={`/courses/${course.slug}`}>{course.title}</a><span>›</span>
      <em>{cls.title}</em>
    </div>

    <article class="class-reader">
      <div class="page-head">
        <div class="eyebrow">{course.title} · Class {(cls.order_index ?? 0) + 1}</div>
        <h1>
          {cls.title}
          {cls.published_at === null && <span class="course-status-chip course-status-draft" style="margin-left: 12px; font-size: 0.5em;">draft</span>}
          {cls.closed_at !== null && <span class="course-status-chip course-status-published" style="margin-left: 12px; font-size: 0.5em;">complete</span>}
        </h1>
        {cls.summary && <p class="kicker">{cls.summary}</p>}
        {canManage && (
          <p style="margin-top: 16px;">
            <a class="btn btn-ghost" href={`/courses/${course.slug}/${cls.slug}/edit`}>Edit class</a>
          </p>
        )}
      </div>

      {bodyHtml ? (
        <div class="class-body" set:html={bodyHtml} />
      ) : (
        <p class="muted italic">No content yet.{canManage && <> <a href={`/courses/${course.slug}/${cls.slug}/edit`}>Add some</a>.</>}</p>
      )}

      <nav class="lesson-nav" style="margin-top: 64px;">
        {showPrev ? (
          <a href={`/courses/${course.slug}/${(prevClass as any).slug}`} class="prev">
            <span class="nav-label">← Previous</span>
            <span class="nav-title">{(prevClass as any).title}</span>
          </a>
        ) : (
          <a href={`/courses/${course.slug}`} class="prev">
            <span class="nav-label">← Back</span>
            <span class="nav-title">Course overview</span>
          </a>
        )}
        {showNext ? (
          <a href={`/courses/${course.slug}/${(nextClass as any).slug}`} class="next">
            <span class="nav-label">Next →</span>
            <span class="nav-title">{(nextClass as any).title}</span>
          </a>
        ) : (
          <a href={`/courses/${course.slug}`} class="next">
            <span class="nav-label">Course overview →</span>
            <span class="nav-title">{course.title}</span>
          </a>
        )}
      </nav>
    </article>
  </main>
</BaseLayout>

<style is:global>
  .class-reader { max-width: 760px; margin: 0 auto; }
  .class-body { margin: 32px 0; line-height: 1.7; }
  .class-body h1 { font-style: italic; font-weight: 500; margin-top: 32px; }
  .class-body h2 { font-style: italic; font-weight: 500; margin-top: 28px; font-size: 1.6rem; }
  .class-body h3 { font-weight: 500; margin-top: 24px; font-size: 1.3rem; }
  .class-body p { margin-bottom: 1em; }
  .class-body ul, .class-body ol { margin: 1em 0; padding-left: 24px; }
  .class-body li { margin-bottom: 0.4em; }
  .class-body code {
    background: rgba(168, 132, 58, 0.18);
    padding: 1px 6px; border-radius: 2px;
    font-family: var(--mono);
  }
  .class-body pre {
    background: var(--ink); color: #ddd0a8;
    padding: 18px 22px; border-left: 3px solid var(--gold);
    overflow-x: auto;
    margin: 16px 0;
  }
  .class-body pre code { background: none; padding: 0; }
  .class-body blockquote {
    border-left: 3px solid var(--gold);
    padding-left: 16px; font-style: italic; color: var(--ink-soft);
    margin: 16px 0;
  }
  .class-body img { max-width: 100%; height: auto; }
  .class-body table { width: 100%; border-collapse: collapse; margin: 16px 0; }
  .class-body th, .class-body td { padding: 10px 14px; border-bottom: 1px solid var(--rule-soft); }
  .class-body th { font-family: var(--display); text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.85rem; }
</style>
