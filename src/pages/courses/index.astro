---
import BaseLayout from '../../layouts/BaseLayout.astro';

export const prerender = false;

const supabase = Astro.locals.supabase;
const canAuthor = Astro.locals.permissions.has('courses.author');

// RLS handles visibility — authors see their drafts; everyone else
// sees only published courses.
const { data: courses, error } = await supabase
  .from('courses')
  .select('id, slug, title, summary, order_mode, published_at, created_by, updated_at')
  .order('updated_at', { ascending: false });

const userId = Astro.locals.user?.id;
const myCourses = (courses ?? []).filter((c: any) => c.created_by === userId);
const publishedCourses = (courses ?? []).filter((c: any) => c.published_at !== null);
const otherDrafts = (courses ?? []).filter((c: any) => c.published_at === null && c.created_by !== userId);

const ok = Astro.url.searchParams.get('ok');
const error_ = Astro.url.searchParams.get('error');
---

<BaseLayout
  title="Courses · Old Toby Academy"
  description="The academy's curriculum."
  activeNav="courses"
  footerVariant="short"
>
  <main class="page">
    <div class="page-head">
      <div class="eyebrow">Catalogue</div>
      <h1>Courses</h1>
      <p class="kicker">Read at your own pace, or follow a sequential cohort. New courses are added by the faculty.</p>
      {canAuthor && (
        <p style="margin-top: 16px;">
          <a class="btn" href="/courses/new">+ New course</a>
        </p>
      )}
    </div>

    {ok === 'deleted'       && <div class="auth-ok">Course deleted.</div>}
    {ok === 'class-deleted' && <div class="auth-ok">Class deleted.</div>}
    {error_                 && <div class="auth-err">{error_}</div>}
    {error                  && <div class="auth-err">Could not load courses: {error.message}</div>}

    {canAuthor && myCourses.length > 0 && (
      <section class="course-section">
        <h2>Your courses</h2>
        <div class="course-list">
          {myCourses.map((c: any) => (
            <a class="course-card" href={`/courses/${c.slug}/edit`}>
              <div class="course-card-head">
                <span class="course-card-title">{c.title}</span>
                {c.published_at === null && <span class="course-status-chip course-status-draft">draft</span>}
                {c.published_at !== null && <span class="course-status-chip course-status-published">published</span>}
                {c.order_mode === 'sequential' && <span class="course-status-chip">sequential</span>}
              </div>
              {c.summary && <p class="course-card-summary">{c.summary}</p>}
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="course-section">
      <h2>Published courses</h2>
      {publishedCourses.length === 0 ? (
        <p class="muted italic">No published courses yet. {canAuthor && <>Want to <a href="/courses/new">make one</a>?</>}</p>
      ) : (
        <div class="course-list">
          {publishedCourses.map((c: any) => (
            <a class="course-card" href={`/courses/${c.slug}`}>
              <div class="course-card-head">
                <span class="course-card-title">{c.title}</span>
                {c.order_mode === 'sequential' && <span class="course-status-chip">sequential</span>}
              </div>
              {c.summary && <p class="course-card-summary">{c.summary}</p>}
            </a>
          ))}
        </div>
      )}
    </section>

    {otherDrafts.length > 0 && (
      <section class="course-section">
        <h2>Other drafts</h2>
        <p class="muted italic">As headmaster, you can see drafts authored by others.</p>
        <div class="course-list">
          {otherDrafts.map((c: any) => (
            <a class="course-card" href={`/courses/${c.slug}`}>
              <div class="course-card-head">
                <span class="course-card-title">{c.title}</span>
                <span class="course-status-chip course-status-draft">draft</span>
              </div>
              {c.summary && <p class="course-card-summary">{c.summary}</p>}
            </a>
          ))}
        </div>
      </section>
    )}
  </main>
</BaseLayout>

<style is:global>
  .course-section { margin-top: 48px; }
  .course-section h2 { font-style: italic; font-weight: 500; margin-bottom: 16px; }
  .course-list {
    display: grid; grid-template-columns: 1fr 1fr; gap: 24px;
  }
  .course-card {
    display: block;
    padding: 24px 28px;
    background: linear-gradient(180deg, rgba(255,250,235,0.55), rgba(217,195,136,0.18));
    border: 1px solid var(--rule-soft);
    text-decoration: none; color: inherit;
    border-bottom: 1px solid var(--rule-soft);
    transition: all 0.15s;
  }
  .course-card:hover {
    border-color: var(--gold);
    background: linear-gradient(180deg, rgba(255,250,235,0.85), rgba(217,195,136,0.3));
  }
  .course-card-head {
    display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
    margin-bottom: 6px;
  }
  .course-card-title {
    font-family: var(--display);
    font-size: 1.4rem;
    color: var(--forest-deep);
    font-weight: 600;
  }
  .course-card-summary { margin: 0; color: var(--ink-soft); font-size: 0.96rem; }
  .course-status-chip {
    font-family: var(--mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 2px 8px;
    border: 1px solid var(--rule-soft);
    color: var(--ink-soft);
    border-radius: 2px;
  }
  .course-status-chip.course-status-draft     { color: var(--oxblood); border-color: var(--oxblood); background: rgba(107, 31, 26, 0.05); }
  .course-status-chip.course-status-published { color: #466928; border-color: #466928; background: rgba(70, 105, 40, 0.05); }

  @media (max-width: 880px) {
    .course-list { grid-template-columns: 1fr; }
  }
</style>
