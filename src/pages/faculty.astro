---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Faculty · Old Toby Academy"
  description="The faculty of Old Toby Academy — founder, archivist, engineer, luthier, scribe, and conductor."
  activeNav="faculty"
  footerVariant="short"
>
  <main class="page">
    <div class="page-head">
      <div class="eyebrow">The People of the Hall</div>
      <h1>Faculty &amp; Fellowship</h1>
      <p class="kicker">A small school keeps a small staff. Roles are kept by archetype rather than by name — the work outlives the wearer.</p>
      <div class="legend">
        <span class="legend-pill"><span class="dot yellow"></span> <span class="smallcaps">Instructors are known by yellow names</span></span>
        <span class="legend-pill"><span class="dot green"></span> <span class="smallcaps">Students by green</span></span>
      </div>
    </div>

    <div class="role-section">
      <h2>The Masters</h2>
      <span class="role-meta">Faculty · Instructors</span>
      <p class="role-desc">Each master tends one or two courses, leading both the readings and the labs. The school is run as a fellowship — every voice in the council, every lesson cross-read.</p>
      <div class="roster">

        <div class="person">
          <div class="portrait">℞</div>
          <div>
            <h3><span class="name yellow">The Founder</span></h3>
            <span class="title">Headmaster · ABC 101 · Song Making 201</span>
            <p>Tends the seal of the school and holds the precepts. Author of the four admonitions of the Final Recital.</p>
            <div class="specialty">ABC · MELODY · BALANCE</div>
          </div>
        </div>

        <div class="person">
          <div class="portrait">𝔉</div>
          <div>
            <h3><span class="name yellow">The Archivist</span></h3>
            <span class="title">Co-administrator · Alumni Hall</span>
            <p>Keeps the library, opens the doors of Alumni Hall, and sees that requests for custom files find a willing scribe.</p>
            <div class="specialty">LIBRARY · ALUMNI · CONDUCT</div>
          </div>
        </div>

        <div class="person">
          <div class="portrait">♬</div>
          <div>
            <h3><span class="name yellow">The Engineer</span></h3>
            <span class="title">MIDI 101 &amp; 201</span>
            <p>Lives inside the spreadsheet view of a midi file. Patient with quantize, ruthless with stuck notes, gentle with the bend-range slider.</p>
            <div class="specialty">REAPER · CHUNKS · EVENTS</div>
          </div>
        </div>

        <div class="person">
          <div class="portrait">𝕴</div>
          <div>
            <h3><span class="name yellow">The Luthier</span></h3>
            <span class="title">Instruments 101 &amp; 201</span>
            <p>Knows the sustain time of every lute, the missing notes of the Student Fiddle, and which drum will overwhelm a song from across the room.</p>
            <div class="specialty">LUTES · FIDDLES · DRUMS</div>
          </div>
        </div>

        <div class="person">
          <div class="portrait">✎</div>
          <div>
            <h3><span class="name yellow">The Scribe</span></h3>
            <span class="title">Song Making 101 · ABC 201</span>
            <p>Teaches the slow art of bringing a tune from ear to file. Will edit your song with you for as long as you have patience for it.</p>
            <div class="specialty">TRANSCRIBE · TEXT · TROUBLESHOOTING</div>
          </div>
        </div>

        <div class="person">
          <div class="portrait">♛</div>
          <div>
            <h3><span class="name yellow">The Conductor</span></h3>
            <span class="title">Final Recital · Concert Bands</span>
            <p>Forms each graduating cohort into a class band. Sets tempo at the green of Bree and gives the cue when the lutes are tuned.</p>
            <div class="specialty">ENSEMBLE · BALANCE · STAGE</div>
          </div>
        </div>

      </div>
    </div>

    <div class="rule-ornament">❦</div>

    <div class="role-section">
      <h2>The Cohort</h2>
      <span class="role-meta">Students · Spring Term</span>
      <p class="role-desc">A typical cohort is small — six to ten — and travels together through both terms. The roster is anonymised for the public catalogue; we know each other by green name in the channels.</p>

      <div class="panel" style="text-align: center; padding: 40px 32px;">
        <p class="pullquote" style="margin: 0 auto; max-width: 56ch; border-left: none; padding-left: 0; text-align: center;">&ldquo;Begin where every musician begins. We will meet you there.&rdquo;</p>
        <a class="btn btn-ghost" href="/courses" style="margin-top: 18px;">See the Curriculum</a>
      </div>
    </div>

  </main>
</BaseLayout>

<style is:global>
  .page-head { padding: 56px 0 24px; border-bottom: 1px double var(--rule); margin-bottom: 48px; }
  .page-head h1 { font-style: italic; font-weight: 500; }

  .legend {
    display: flex; gap: 32px; align-items: center; flex-wrap: wrap;
    margin: 16px 0 0; font-size: 0.95rem;
  }
  .legend-pill { display: inline-flex; align-items: center; gap: 10px; }
  .dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; box-shadow: 0 0 0 1px rgba(0,0,0,0.2); }
  .dot.yellow { background: #d4b042; }
  .dot.green { background: #5e8a3a; }

  .roster { display: grid; grid-template-columns: repeat(2, 1fr); gap: 28px; }
  .role-section { margin-top: 32px; }
  .role-section h2 {
    font-style: italic; font-weight: 500; margin-bottom: 6px;
    display: flex; align-items: baseline; gap: 14px;
  }
  .role-section .role-meta {
    font-family: var(--display); letter-spacing: 0.3em;
    color: var(--gold); font-size: 0.85rem; text-transform: uppercase;
  }
  .role-section .role-desc {
    color: var(--ink-soft); font-style: italic; max-width: 60ch; margin-bottom: 24px;
  }

  .person {
    display: grid; grid-template-columns: 90px 1fr; gap: 18px;
    padding: 20px 22px; background: rgba(255, 250, 235, 0.4);
    border: 1px solid var(--rule-soft); align-items: start;
  }
  .person .portrait {
    width: 90px; height: 90px; border-radius: 50%;
    background: var(--forest); display: flex; align-items: center; justify-content: center;
    font-family: var(--display); font-size: 2.2rem; color: var(--gold);
    border: 2px solid var(--gold); position: relative;
  }
  .person .portrait::after {
    content: ""; position: absolute; inset: 4px;
    border: 1px solid var(--gold); border-radius: 50%; opacity: 0.4;
  }
  .person h3 { margin: 2px 0 2px; font-size: 1.3rem; display: flex; align-items: center; gap: 8px; }
  .person h3 .name { color: var(--ink); }
  .person h3 .name.yellow { color: #8a6e1d; }
  .person h3 .name.green { color: #466928; }
  .person .title {
    font-style: italic; color: var(--oxblood);
    font-size: 0.95rem; margin-bottom: 6px; display: block;
  }
  .person p { font-size: 0.95rem; margin: 0 0 8px; color: var(--ink-soft); }
  .person .specialty {
    font-family: var(--mono); font-size: 0.72rem; letter-spacing: 0.12em;
    color: var(--gold); text-transform: uppercase;
  }

  @media (max-width: 880px) {
    .roster { grid-template-columns: 1fr; }
    .nav { display: none; }
  }
</style>
