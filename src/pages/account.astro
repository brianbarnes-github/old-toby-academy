---
import BaseLayout from '../layouts/BaseLayout.astro';

export const prerender = false;

const profile = Astro.locals.profile;
const user = Astro.locals.user;
const supabase = Astro.locals.supabase;

if (!user || !profile) {
  return Astro.redirect('/login');
}

const error = Astro.url.searchParams.get('error');
const ok = Astro.url.searchParams.get('ok');

// Roles held by the member, for the identity panel
const { data: memberRoles } = await supabase
  .from('user_roles')
  .select('roles(slug, name)')
  .eq('user_id', user.id);

const roleSlugs = (memberRoles ?? []).map((r: any) => r.roles?.slug).filter(Boolean);

const LEVELS = ['none', 'beginner', 'intermediate', 'advanced', 'expert'] as const;
---

<BaseLayout
  title="My Account · Old Toby Academy"
  description="Update your password and profile."
  footerVariant="short"
>
  <main class="page">
    <div class="page-head">
      <div class="eyebrow">Your Quarters</div>
      <h1 class:list={[`member-name-${profile.role}`]}>{profile.character_name ?? '(no name)'}</h1>
      <p class="kicker">
        {profile.server && <>Server: <strong>{profile.server}</strong> · </>}
        Joined: <strong>{new Date(profile.created_at).toLocaleDateString()}</strong>
        {roleSlugs.length > 0 && (
          <> · Roles: {roleSlugs.map((s: string) => <span class={`role-chip role-chip-${s}`} style="margin-left: 4px;">{s}</span>)}</>
        )}
      </p>
    </div>

    {error && <div class="auth-err">{error}</div>}
    {ok === 'server'   && <div class="auth-ok">Server saved.</div>}
    {ok === 'password' && <div class="auth-ok">Password changed. Use the new one next time you sign in.</div>}
    {ok === 'profile'  && <div class="auth-ok">Profile updated.</div>}

    <div class="account-grid">
      <!-- Server -->
      <section class="account-section">
        <h2>Server</h2>
        <p class="muted italic">Optional. Useful for finding cohort-mates.</p>
        <form class="auth-form" method="POST" action="/api/account/update-server">
          <label>Your server
            <input type="text" name="server" value={profile.server ?? ''} placeholder="e.g. Sting" />
          </label>
          <button class="btn" type="submit">Save server</button>
        </form>
      </section>

      <!-- Password -->
      <section class="account-section">
        <h2>Change password</h2>
        <p class="muted italic">Pick something at least 6 characters long. We'll verify your current password before changing.</p>
        <form class="auth-form" method="POST" action="/api/account/change-password">
          <label>Current password
            <input type="password" name="current_password" required autocomplete="current-password" />
          </label>
          <label>New password
            <input type="password" name="new_password" required minlength="6" autocomplete="new-password" />
          </label>
          <label>Confirm new password
            <input type="password" name="new_password_confirm" required minlength="6" autocomplete="new-password" />
          </label>
          <button class="btn" type="submit">Change password</button>
        </form>
      </section>
    </div>

    <!-- Experience profile (full-width) -->
    <section class="account-section account-section-wide">
      <h2>Experience profile</h2>
      <p class="muted italic">Update your answers to the welcome questions. Helps the faculty place you with the right cohort.</p>
      <form class="auth-form welcome-profile-form" method="POST" action="/api/account/update-profile">
        {[
          { name: 'music_level',        label: 'Music experience (general)' },
          { name: 'ingame_music_level', label: 'In-game music experience' },
          { name: 'technical_level',    label: 'Technical & computer experience' },
        ].map(({ name, label }) => (
          <fieldset class="exp-fieldset">
            <legend>{label}</legend>
            <div class="exp-options">
              {LEVELS.map((level) => {
                const id = `${name}-${level}`;
                const checked = (profile as any)[name] === level;
                return (
                  <label class="exp-option" for={id}>
                    <input type="radio" id={id} name={name} value={level} required checked={checked} />
                    <span>{level}</span>
                  </label>
                );
              })}
            </div>
          </fieldset>
        ))}

        <label>What you hope to get from this effort
          <textarea name="hopes" rows="4" required>{profile.hopes ?? ''}</textarea>
        </label>

        <button class="btn" type="submit">Save profile</button>
      </form>
    </section>

    <p class="muted italic" style="margin-top: 64px; font-size: 0.92rem;">
      Need to change your character name or remove your account? Ask the headmaster.
    </p>
  </main>
</BaseLayout>

<style is:global>
  .account-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    margin-top: 32px;
  }
  .account-section {
    background: linear-gradient(180deg, rgba(255,250,235,0.55), rgba(217,195,136,0.12));
    border: 1px solid var(--rule-soft);
    padding: 28px 32px;
  }
  .account-section h2 {
    font-style: italic;
    font-weight: 500;
    margin-bottom: 4px;
  }
  .account-section .muted { margin-bottom: 16px; }
  .account-section-wide { margin-top: 32px; }

  .member-name-headmaster { color: var(--oxblood); }
  .member-name-faculty    { color: #8a6e1d; }
  .member-name-student    { color: #466928; }

  @media (max-width: 880px) {
    .account-grid { grid-template-columns: 1fr; }
  }
</style>
