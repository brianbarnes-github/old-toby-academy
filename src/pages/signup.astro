---
import BaseLayout from '../layouts/BaseLayout.astro';

export const prerender = false;
---

<BaseLayout
  title="Redeem a Token · Old Toby Academy"
  description="Redeem an invite token to join the academy."
  footerVariant="short"
>
  <main class="page">
    <div class="auth-wrap">
      <div class="eyebrow">Token Redemption</div>
      <h1>Soon, scribe.</h1>
      <p class="kicker">The headmaster's token-redemption table is being prepared. If you've been given an invite token, hold it for the moment — the redemption flow will arrive in the next iteration of the Hall.</p>
      <p class="auth-aside">Already a member? <a href="/login">Sign in</a>.</p>
    </div>
  </main>
</BaseLayout>
