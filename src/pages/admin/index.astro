---
import BaseLayout from '../../layouts/BaseLayout.astro';

export const prerender = false;

const profile = Astro.locals.profile;
const supabase = Astro.locals.supabase;

const { count: tokenCount } = await supabase
  .from('invite_tokens')
  .select('*', { count: 'exact', head: true });

const { count: userCount } = await supabase
  .from('profiles')
  .select('*', { count: 'exact', head: true });
---

<BaseLayout
  title="Admin · Old Toby Academy"
  description="Headmaster administration."
  footerVariant="short"
>
  <main class="page">
    <div class="page-head">
      <div class="eyebrow">Headmaster's Study</div>
      <h1>Administration</h1>
      <p class="kicker">Welcome, {profile?.character_name || 'Headmaster'}. From here you can mint invite tokens and oversee the cohort.</p>
    </div>

    <div class="admin-grid">
      <a class="admin-card" href="/admin/tokens">
        <div class="admin-card-num">{tokenCount ?? 0}</div>
        <h2>Invite Tokens</h2>
        <p>Generate new invite tokens, view active and used tokens.</p>
        <span class="admin-cta">Manage tokens →</span>
      </a>

      <div class="admin-card admin-card-disabled">
        <div class="admin-card-num">{userCount ?? 0}</div>
        <h2>Members</h2>
        <p>List, promote, or demote students and faculty.</p>
        <span class="admin-cta">Coming in Phase 4</span>
      </div>
    </div>
  </main>
</BaseLayout>

<style is:global>
  .admin-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 28px; margin-top: 32px; }
  .admin-card {
    display: block;
    background: linear-gradient(180deg, rgba(255,250,235,0.55), rgba(217,195,136,0.18));
    border: 1px solid var(--rule);
    box-shadow: 0 0 0 6px var(--parchment), 0 0 0 7px var(--rule-soft);
    padding: 32px 36px;
    text-decoration: none;
    color: inherit;
    border-bottom: 1px solid var(--rule);
    transition: background 0.15s;
  }
  .admin-card:hover {
    background: linear-gradient(180deg, rgba(255,250,235,0.85), rgba(217,195,136,0.3));
    border-color: var(--gold);
  }
  .admin-card.admin-card-disabled { opacity: 0.6; pointer-events: none; }
  .admin-card-num {
    font-family: var(--display);
    font-style: italic;
    color: var(--oxblood);
    font-size: 3.6rem;
    line-height: 1;
    margin-bottom: 8px;
  }
  .admin-card h2 { font-style: italic; font-weight: 500; margin-bottom: 6px; }
  .admin-card p { font-size: 0.96rem; color: var(--ink-soft); margin-bottom: 14px; }
  .admin-cta {
    font-family: var(--display);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-size: 0.85rem;
    color: var(--oxblood);
    font-weight: 600;
  }

  @media (max-width: 880px) {
    .admin-grid { grid-template-columns: 1fr; }
  }
</style>
