---
import BaseLayout from '../../layouts/BaseLayout.astro';

export const prerender = false;

const profile = Astro.locals.profile;
const supabase = Astro.locals.supabase;
const perms = Astro.locals.permissions;

const has = (slug: string) => perms.has(slug);
const hasAny = (...slugs: string[]) => slugs.some(has);

const canTokens = hasAny('tokens.list', 'tokens.mint', 'tokens.revoke');
const canUsers  = hasAny('users.list', 'users.assign_roles');
const canRoles  = has('roles.manage');
const canAudit  = has('audit.read');

const counts: Record<string, number | null> = { tokens: null, users: null, entries: null, roles: null };

if (canTokens) {
  const { count } = await supabase.from('invite_tokens').select('*', { count: 'exact', head: true });
  counts.tokens = count ?? 0;
}
if (canUsers) {
  const { count } = await supabase.from('profiles').select('*', { count: 'exact', head: true });
  counts.users = count ?? 0;
}
if (canAudit) {
  const { count } = await supabase.from('entries').select('*', { count: 'exact', head: true });
  counts.entries = count ?? 0;
}
if (canRoles) {
  const { count } = await supabase.from('roles').select('*', { count: 'exact', head: true });
  counts.roles = count ?? 0;
}
---

<BaseLayout
  title="Admin · Old Toby Academy"
  description="Headmaster administration."
  footerVariant="short"
>
  <main class="page">
    <div class="page-head">
      <div class="eyebrow">Headmaster's Study</div>
      <h1>Administration</h1>
      <p class="kicker">Welcome, {profile?.character_name || 'Headmaster'}. From here you can mint invite tokens and oversee the cohort.</p>
    </div>

    <div class="admin-grid">
      {canTokens && (
        <a class="admin-card" href="/admin/tokens">
          <div class="admin-card-num">{counts.tokens ?? 0}</div>
          <h2>Invite Tokens</h2>
          <p>Generate new invite tokens, view active and used tokens, and the recipient note for each.</p>
          <span class="admin-cta">Manage tokens →</span>
        </a>
      )}

      {canUsers && (
        <a class="admin-card" href="/admin/users">
          <div class="admin-card-num">{counts.users ?? 0}</div>
          <h2>Members</h2>
          <p>Browse the cohort. Click a member to add or remove roles.</p>
          <span class="admin-cta">Manage members →</span>
        </a>
      )}

      {canRoles && (
        <>
          <a class="admin-card" href="/admin/roles">
            <div class="admin-card-num">{counts.roles ?? 0}</div>
            <h2>Roles</h2>
            <p>Define roles and bundle abilities. System roles can be re-bundled but not deleted.</p>
            <span class="admin-cta">Manage roles →</span>
          </a>

          <a class="admin-card" href="/admin/permissions">
            <div class="admin-card-num">·</div>
            <h2>Abilities</h2>
            <p>The catalog of abilities the academy code knows about. Read-only.</p>
            <span class="admin-cta">View catalog →</span>
          </a>
        </>
      )}

      {canAudit && (
        <a class="admin-card" href="/admin/log">
          <div class="admin-card-num">{counts.entries ?? 0}</div>
          <h2>Audit Log</h2>
          <p>A timestamped record of every meaningful event — token redemptions, role changes, onboarding milestones.</p>
          <span class="admin-cta">View log →</span>
        </a>
      )}
    </div>
  </main>
</BaseLayout>

<style is:global>
  .admin-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 24px; margin-top: 32px; }
  .admin-card {
    display: block;
    background: linear-gradient(180deg, rgba(255,250,235,0.55), rgba(217,195,136,0.18));
    border: 1px solid var(--rule);
    box-shadow: 0 0 0 6px var(--parchment), 0 0 0 7px var(--rule-soft);
    padding: 32px 36px;
    text-decoration: none;
    color: inherit;
    border-bottom: 1px solid var(--rule);
    transition: background 0.15s;
  }
  .admin-card:hover {
    background: linear-gradient(180deg, rgba(255,250,235,0.85), rgba(217,195,136,0.3));
    border-color: var(--gold);
  }
  .admin-card.admin-card-disabled { opacity: 0.6; pointer-events: none; }
  .admin-card-num {
    font-family: var(--display);
    font-style: italic;
    color: var(--oxblood);
    font-size: 3.6rem;
    line-height: 1;
    margin-bottom: 8px;
  }
  .admin-card h2 { font-style: italic; font-weight: 500; margin-bottom: 6px; }
  .admin-card p { font-size: 0.96rem; color: var(--ink-soft); margin-bottom: 14px; }
  .admin-cta {
    font-family: var(--display);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-size: 0.85rem;
    color: var(--oxblood);
    font-weight: 600;
  }

  @media (max-width: 880px) {
    .admin-grid { grid-template-columns: 1fr; }
  }
</style>
