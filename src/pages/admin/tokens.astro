---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CsrfField from '../../components/CsrfField.astro';

export const prerender = false;

const supabase = Astro.locals.supabase;
const error = Astro.url.searchParams.get('error');
const newToken = Astro.url.searchParams.get('new');
const newRole = Astro.url.searchParams.get('role');
const revoked = Astro.url.searchParams.get('revoked');

const { data: tokens, error: listErr } = await supabase
  .from('invite_tokens_admin')
  .select('*');

const origin = Astro.url.origin;
const newTokenLink = newToken ? `${origin}/signup?token=${newToken}` : null;
---

<BaseLayout
  title="Invite Tokens · Admin · Old Toby Academy"
  description="Generate and manage invite tokens."
  footerVariant="short"
>
  <main class="page">
    <div class="crumbs">
      <a href="/admin">Admin</a><span>›</span>
      <em>Invite Tokens</em>
    </div>

    <div class="page-head">
      <div class="eyebrow">Headmaster's Study</div>
      <h1>Invite Tokens</h1>
      <p class="kicker">Mint a token, copy the link, hand it out (Discord, in-game, parchment scroll). The recipient pastes the token at <code>/signup</code> to create an account.</p>
    </div>

    {error && <div class="auth-err">{error}</div>}
    {revoked && <div class="auth-ok">Token revoked. The recipient can no longer redeem it.</div>}

    {newToken && (
      <div class="token-banner">
        <div class="eyebrow">New {newRole} token minted</div>
        <p class="token-banner-sub">Copy this — you'll only see it once in this banner. (It's also in the table below.)</p>
        <div class="token-display">
          <code class="token-code">{newToken}</code>
          <button type="button" class="copy-btn" data-copy={newToken}>Copy token</button>
        </div>
        <div class="token-display">
          <span class="token-label">Direct link:</span>
          <code class="token-code">{newTokenLink}</code>
          <button type="button" class="copy-btn" data-copy={newTokenLink}>Copy link</button>
        </div>
      </div>
    )}

    <div class="admin-section">
      <h2>Generate a new token</h2>
      <form class="token-form" method="POST" action="/api/generate-token">
        <CsrfField />
        <label>Role
          <select name="role" required>
            <option value="student" selected>Student</option>
            <option value="faculty">Faculty</option>
          </select>
        </label>
        <label>Expires after (days)
          <input type="number" name="expires_days" value="30" min="0" max="365" />
        </label>
        <label class="token-form-wide">Recipient note (optional)
          <input type="text" name="notes" placeholder="e.g. Pippin from Discord" maxlength="120" />
        </label>
        <button class="btn" type="submit">Mint token</button>
      </form>
      <p class="muted italic" style="margin-top: 8px;">Set expiry days to <code>0</code> for no expiry. The note helps you reconcile who you sent each token to.</p>
    </div>

    <div class="admin-section">
      <h2>All tokens</h2>
      {listErr ? (
        <p class="auth-err">Could not load tokens: {listErr.message}</p>
      ) : tokens && tokens.length > 0 ? (
        <table class="nice-table token-table">
          <thead>
            <tr>
              <th style="width:24%;">Token</th>
              <th>Role</th>
              <th>Status</th>
              <th>Recipient</th>
              <th>Expires</th>
              <th>Created</th>
              <th style="width:1%;"></th>
            </tr>
          </thead>
          <tbody>
            {tokens.map((t: any) => (
              <tr>
                <td class="mono token-cell"><code>{t.token}</code></td>
                <td>{t.role}</td>
                <td><span class={`token-status token-status-${t.status}`}>{t.status}</span></td>
                <td class="token-notes">{t.notes ?? <span class="muted">—</span>}</td>
                <td>{t.expires_at ? new Date(t.expires_at).toLocaleDateString() : '—'}</td>
                <td>{new Date(t.created_at).toLocaleDateString()}</td>
                <td class="token-actions">
                  <button type="button" class="row-action copy-btn" data-copy={t.token} title="Copy token">Copy</button>
                  <button type="button" class="row-action copy-btn" data-copy={`${origin}/signup?token=${t.token}`} title="Copy signup link">Link</button>
                  {t.status === 'active' && (
                    <form method="POST" action="/api/revoke-token" class="revoke-form" onsubmit="return confirm('Revoke this token? It cannot be undone — the recipient will not be able to redeem it.');">
                      <CsrfField />
                      <input type="hidden" name="token" value={t.token} />
                      <button type="submit" class="row-action row-action-danger" title="Revoke token">Revoke</button>
                    </form>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      ) : (
        <p class="muted italic">No tokens yet. Mint your first one above.</p>
      )}
    </div>
  </main>
</BaseLayout>

<script is:inline>
  // Single delegated handler for any [data-copy] button on the page.
  document.addEventListener('click', async (e) => {
    const btn = e.target.closest('.copy-btn');
    if (!btn) return;
    const text = btn.dataset.copy;
    if (!text) return;
    const original = btn.textContent;
    try {
      await navigator.clipboard.writeText(text);
      btn.textContent = 'Copied!';
      btn.classList.add('copy-btn-ok');
    } catch (err) {
      btn.textContent = 'Copy failed';
      btn.classList.add('copy-btn-err');
    }
    setTimeout(() => {
      btn.textContent = original;
      btn.classList.remove('copy-btn-ok', 'copy-btn-err');
    }, 1400);
  });
</script>

<style is:global>
  .admin-section { margin-top: 48px; }
  .admin-section h2 { font-style: italic; font-weight: 500; margin-bottom: 16px; }

  .auth-ok {
    background: rgba(70, 105, 40, 0.10);
    border-left: 3px solid #466928;
    color: #2f491a;
    padding: 12px 16px; margin: 0 0 20px;
    font-size: 0.95rem; font-style: italic;
  }

  .token-banner {
    margin-top: 24px; padding: 24px 28px;
    background: linear-gradient(180deg, rgba(168, 132, 58, 0.18), rgba(168, 132, 58, 0.06));
    border: 1px solid var(--gold);
    box-shadow: 0 0 0 6px var(--parchment), 0 0 0 7px var(--gold);
  }
  .token-banner-sub { font-style: italic; color: var(--ink-soft); margin-bottom: 14px; }
  .token-display {
    display: flex; align-items: center; gap: 12px; margin: 8px 0;
    flex-wrap: wrap;
  }
  .token-label { font-family: var(--display); font-size: 0.85rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--ink-soft); }
  .token-code {
    font-family: var(--mono); font-size: 0.95rem;
    background: var(--ink); color: #ddd0a8;
    padding: 6px 12px; border-radius: 2px;
    word-break: break-all;
    flex: 1 1 auto;
  }

  .copy-btn {
    font-family: var(--display);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 6px 14px;
    border: 1px solid var(--ink);
    background: var(--ink);
    color: var(--parchment);
    cursor: pointer;
    transition: all 0.15s;
    white-space: nowrap;
  }
  .copy-btn:hover { background: var(--forest-deep); border-color: var(--forest-deep); }
  .copy-btn.copy-btn-ok { background: #466928; border-color: #466928; }
  .copy-btn.copy-btn-err { background: var(--oxblood); border-color: var(--oxblood); }

  .token-form {
    display: flex; flex-wrap: wrap; gap: 16px; align-items: flex-end;
    padding: 24px;
    background: rgba(255, 250, 235, 0.4);
    border: 1px solid var(--rule-soft);
  }
  .token-form label {
    display: flex; flex-direction: column; gap: 4px;
    font-family: var(--display); font-size: 0.85rem;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--ink-soft);
  }
  .token-form input,
  .token-form select {
    font-family: var(--body); font-size: 1rem;
    padding: 8px 12px;
    background: rgba(255, 250, 235, 0.7);
    border: 1px solid var(--rule-soft); border-radius: 2px;
    color: var(--ink); letter-spacing: 0; text-transform: none;
    min-width: 180px;
  }
  .token-form input:focus, .token-form select:focus {
    outline: none; border-color: var(--gold);
  }
  .token-form .token-form-wide { flex: 1; min-width: 240px; }
  .token-form .token-form-wide input { width: 100%; }
  .token-table .token-notes { font-style: italic; color: var(--ink-soft); }

  .token-table { font-size: 0.92rem; }
  .token-table .token-cell { word-break: break-all; }
  .token-table .token-cell code {
    background: rgba(31, 58, 46, 0.06);
    padding: 2px 6px; border-radius: 2px;
  }
  .token-status {
    font-family: var(--mono);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 2px 8px;
    border: 1px solid;
  }
  .token-status-active  { color: var(--forest-deep); border-color: var(--forest-deep); }
  .token-status-used    { color: var(--ink-soft); border-color: var(--rule-soft); }
  .token-status-expired { color: var(--oxblood); border-color: var(--oxblood); }
  .token-status-revoked { color: #6b1f1a; border-color: #6b1f1a; background: rgba(107, 31, 26, 0.06); }

  .token-actions { white-space: nowrap; display: flex; gap: 4px; align-items: center; }
  .token-actions .revoke-form { display: inline; margin: 0; }
  .row-action {
    font-family: var(--display);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 4px 8px;
    border: 1px solid var(--rule-soft);
    background: rgba(255, 250, 235, 0.6);
    color: var(--ink-soft);
    cursor: pointer;
    transition: all 0.12s;
    white-space: nowrap;
  }
  .row-action:hover { border-color: var(--ink); color: var(--ink); }
  .row-action-danger:hover { border-color: var(--oxblood); color: var(--oxblood); background: rgba(107, 31, 26, 0.06); }
  .row-action.copy-btn-ok { background: #466928; color: var(--parchment); border-color: #466928; }
  .row-action.copy-btn-err { background: var(--oxblood); color: var(--parchment); border-color: var(--oxblood); }
</style>
