---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CsrfField from '../../../components/CsrfField.astro';

export const prerender = false;

const supabase = Astro.locals.supabase;
const { user_id } = Astro.params;
const error = Astro.url.searchParams.get('error');
const ok = Astro.url.searchParams.get('ok');

if (!user_id) {
  return Astro.redirect('/admin/users');
}

const { data: profile, error: profileErr } = await supabase
  .from('profiles')
  .select('*')
  .eq('user_id', user_id)
  .maybeSingle();

if (profileErr || !profile) {
  return Astro.redirect('/admin/users?error=' + encodeURIComponent('Member not found.'));
}

// Roles this member already has
const { data: memberRoles } = await supabase
  .from('user_roles')
  .select('role_id, granted_at, roles(id, slug, name, is_system)')
  .eq('user_id', user_id);

const heldRoleIds = new Set((memberRoles ?? []).map((mr: any) => mr.role_id));

// All roles in the system
const { data: allRoles } = await supabase
  .from('roles')
  .select('id, slug, name, is_system')
  .order('is_system', { ascending: false })
  .order('name');

const availableRoles = (allRoles ?? []).filter((r: any) => !heldRoleIds.has(r.id));
---

<BaseLayout
  title={`${profile.character_name ?? 'Member'} · Admin · Old Toby Academy`}
  description={`Manage roles for ${profile.character_name ?? 'this member'}.`}
  footerVariant="short"
>
  <main class="page">
    <div class="crumbs">
      <a href="/admin">Admin</a><span>›</span>
      <a href="/admin/users">Members</a><span>›</span>
      <em>{profile.character_name ?? '(no name)'}</em>
    </div>

    <div class="page-head admin-user-head">
      {profile.avatar_url ? (
        <img src={profile.avatar_url} alt="" class="admin-user-avatar" />
      ) : (
        <div class={`admin-user-avatar admin-user-avatar-default admin-user-avatar-${profile.role}`}>
          {(profile.character_name ?? '?').slice(0, 1).toUpperCase()}
        </div>
      )}
      <div>
        <div class="eyebrow">Headmaster's Study</div>
        <h1 class:list={[`member-name-${profile.role}`]}>{profile.character_name ?? '(no name)'}</h1>
        <p class="kicker">
          {profile.server && <>Server: <strong>{profile.server}</strong> · </>}
          Joined: <strong>{new Date(profile.created_at).toLocaleDateString()}</strong> ·
          Onboarded: <strong>{profile.onboarding_completed_at ? new Date(profile.onboarding_completed_at).toLocaleDateString() : 'no'}</strong>
        </p>
        {profile.bio && <p class="admin-user-bio">{profile.bio}</p>}
      </div>
    </div>

    {error && <div class="auth-err">{error}</div>}
    {ok && <div class="auth-ok">Saved.</div>}

    <div class="admin-section">
      <h2>Roles held</h2>
      {memberRoles && memberRoles.length > 0 ? (
        <ul class="role-list">
          {memberRoles.map((mr: any) => (
            <li class="role-list-item">
              <span class={`role-chip role-chip-${mr.roles.slug}`}>{mr.roles.slug}</span>
              <span class="role-list-name">{mr.roles.name}</span>
              {mr.roles.is_system && <span class="system-flag">system</span>}
              <span class="role-list-meta mono small">granted {new Date(mr.granted_at).toLocaleDateString()}</span>
              <form method="POST" action="/api/admin/revoke-role" class="inline-form" onsubmit="return confirm('Remove this role from the member?');">
                <CsrfField />
                <input type="hidden" name="user_id" value={user_id} />
                <input type="hidden" name="role_id" value={mr.roles.id} />
                <input type="hidden" name="back" value={`/admin/users/${user_id}`} />
                <button class="row-action row-action-danger" type="submit">Revoke</button>
              </form>
            </li>
          ))}
        </ul>
      ) : (
        <p class="muted italic">No roles assigned.</p>
      )}
    </div>

    {availableRoles.length > 0 && (
      <div class="admin-section">
        <h2>Add a role</h2>
        <form method="POST" action="/api/admin/grant-role" class="grant-role-form">
          <CsrfField />
          <input type="hidden" name="user_id" value={user_id} />
          <input type="hidden" name="back" value={`/admin/users/${user_id}`} />
          <label>Pick a role
            <select name="role_id" required>
              <option value="">— select —</option>
              {availableRoles.map((r: any) => (
                <option value={r.id}>{r.name} ({r.slug}){r.is_system ? ' · system' : ''}</option>
              ))}
            </select>
          </label>
          <button class="btn" type="submit">Grant role</button>
        </form>
      </div>
    )}

    <div class="admin-section">
      <h2>Profile snapshot</h2>
      <dl class="profile-dl">
        <dt>Music experience</dt><dd>{profile.music_level ?? <span class="muted">—</span>}</dd>
        <dt>In-game music experience</dt><dd>{profile.ingame_music_level ?? <span class="muted">—</span>}</dd>
        <dt>Technical experience</dt><dd>{profile.technical_level ?? <span class="muted">—</span>}</dd>
        <dt>Hopes</dt><dd>{profile.hopes ?? <span class="muted">—</span>}</dd>
      </dl>
    </div>

    {Astro.locals.permissions.has('users.reset_password') && (
      <div class="admin-section">
        <h2>Reset password</h2>
        <p class="muted italic">Generates a one-time temporary password for this member. They use it once to sign in, then change it themselves. Headmaster delivers it out-of-band (Discord, in-game).</p>

        <div id="temp-password-banner" class="token-banner" hidden>
          <div class="eyebrow">New temporary password</div>
          <p class="token-banner-sub">Copy this — it's shown only once. The member uses it on their next sign-in.</p>
          <div class="token-display">
            <code class="token-code" id="temp-password-text">—</code>
            <button type="button" class="copy-btn" id="temp-password-copy">Copy password</button>
          </div>
        </div>

        <form method="POST" action="/api/admin/reset-password" onsubmit="return confirm('Reset this member’s password? Their current password will stop working immediately.');">
          <CsrfField />
          <input type="hidden" name="user_id" value={user_id} />
          <input type="hidden" name="back" value={`/admin/users/${user_id}`} />
          <button class="btn btn-ghost" type="submit" style="border-color: var(--oxblood); color: var(--oxblood);">Reset password</button>
        </form>
      </div>
    )}
  </main>

  <script is:inline>
    // Read a temporary password from the URL hash (#temp=...) once and
    // display it in the banner. Then strip the hash from the URL so it
    // doesn't survive in browser history or sit on a refresh.
    (function () {
      const hash = window.location.hash;
      if (!hash || !hash.startsWith('#temp=')) return;

      const password = decodeURIComponent(hash.slice('#temp='.length));
      const banner = document.getElementById('temp-password-banner');
      const text = document.getElementById('temp-password-text');
      const copy = document.getElementById('temp-password-copy');
      if (!banner || !text || !copy) return;

      text.textContent = password;
      copy.dataset.copy = password;
      banner.hidden = false;

      // Replace the URL with the same path, no hash, no scroll.
      history.replaceState(null, '', window.location.pathname + window.location.search);

      banner.scrollIntoView({ behavior: 'smooth', block: 'center' });
    })();

    // Copy-to-clipboard handler for any [data-copy] / .copy-btn button.
    document.addEventListener('click', async (e) => {
      const btn = e.target.closest('.copy-btn');
      if (!btn) return;
      const text = btn.dataset.copy;
      if (!text) return;
      const original = btn.textContent;
      try {
        await navigator.clipboard.writeText(text);
        btn.textContent = 'Copied!';
        btn.classList.add('copy-btn-ok');
      } catch (err) {
        btn.textContent = 'Copy failed';
        btn.classList.add('copy-btn-err');
      }
      setTimeout(() => {
        btn.textContent = original;
        btn.classList.remove('copy-btn-ok', 'copy-btn-err');
      }, 1400);
    });
  </script>
</BaseLayout>

<style is:global>
  .role-list { list-style: none; padding: 0; margin: 0; }
  .role-list-item {
    display: flex; align-items: center; gap: 14px; flex-wrap: wrap;
    padding: 12px 0;
    border-bottom: 1px dotted var(--rule-soft);
  }
  .role-list-item:last-child { border-bottom: none; }
  .role-list-name { font-family: var(--display); font-size: 1.05rem; color: var(--forest-deep); }
  .role-list-meta { color: var(--ink-soft); }
  .system-flag {
    font-family: var(--mono); font-size: 0.7rem;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--gold); border: 1px solid var(--gold);
    padding: 2px 6px;
  }
  .inline-form { margin: 0 0 0 auto; display: inline; }

  .grant-role-form {
    display: flex; gap: 14px; align-items: flex-end;
    padding: 18px 22px;
    background: rgba(255, 250, 235, 0.4);
    border: 1px solid var(--rule-soft);
  }
  .grant-role-form label {
    flex: 1; min-width: 220px;
    display: flex; flex-direction: column; gap: 4px;
    font-family: var(--display); font-size: 0.85rem;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--ink-soft);
  }
  .grant-role-form select {
    font-family: var(--body); font-size: 1rem; padding: 8px 12px;
    background: rgba(255, 250, 235, 0.7);
    border: 1px solid var(--rule-soft); border-radius: 2px;
    color: var(--ink); letter-spacing: 0; text-transform: none;
  }

  .profile-dl {
    display: grid; grid-template-columns: max-content 1fr;
    gap: 8px 24px; font-size: 0.95rem;
  }
  .profile-dl dt {
    font-family: var(--display);
    font-size: 0.82rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-soft);
    padding-top: 2px;
  }
  .profile-dl dd { margin: 0; }

  .admin-user-head { display: flex; align-items: flex-start; gap: 28px; flex-wrap: wrap; }
  .admin-user-avatar {
    width: 96px; height: 96px; border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--gold);
    box-shadow: 0 0 0 4px var(--parchment);
    flex-shrink: 0;
  }
  .admin-user-avatar-default {
    background: var(--forest);
    color: var(--gold);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--display);
    font-size: 2.4rem;
    font-weight: 700;
  }
  .admin-user-avatar-default.admin-user-avatar-headmaster { background: var(--oxblood); border-color: var(--oxblood); color: var(--gold); }
  .admin-user-avatar-default.admin-user-avatar-faculty    { background: #8a6e1d; border-color: #8a6e1d; color: var(--parchment); }
  .admin-user-avatar-default.admin-user-avatar-student    { background: var(--forest); border-color: #466928; color: var(--gold); }
  .admin-user-bio {
    margin-top: 12px;
    padding: 12px 16px;
    background: rgba(31, 58, 46, 0.04);
    border-left: 3px solid var(--gold);
    font-style: italic;
    max-width: 56ch;
  }
</style>
