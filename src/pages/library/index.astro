---
import BaseLayout from '../../layouts/BaseLayout.astro';

export const prerender = false;

const canContribute = Astro.locals.permissions.has('library.contribute');

const chapters = [
  {
    numeral: 'I',
    href: '/library/foundations',
    title: 'Foundations',
    summary: 'Western music, the staff and clefs, note values, and rests.',
  },
  {
    numeral: 'II',
    href: '/library/scales-and-modes',
    title: 'Scales & Modes',
    summary: 'Major and minor scales, chromaticism, and the seven church modes.',
  },
  {
    numeral: 'III',
    href: '/library/rhythm-and-meter',
    title: 'Rhythm & Meter',
    summary: 'Time signatures, syncopation, and the feel of meter across genres.',
  },
  {
    numeral: 'IV',
    href: '/library/key-signatures',
    title: 'Key Signatures & the Circle of Fifths',
    summary: 'Major and minor keys, modulation, and the diagram that ties them together.',
  },
  {
    numeral: 'V',
    href: '/library/intervals',
    title: 'Intervals & Scale Construction',
    summary: 'Interval qualities, scale-building patterns, and named scale degrees.',
  },
  {
    numeral: 'VI',
    href: '/library/chords',
    title: 'Triads & Chords',
    summary: 'Triad qualities, chord families, harmonic function, and common progressions.',
  },
];
---

<BaseLayout
  title="The Library · Old Toby Academy"
  description="A reference of Western music theory — scales, modes, rhythm, keys, intervals, and chords."
  activeNav="library"
  footerVariant="short"
>
  <main class="page">
    <div class="page-head">
      <div class="eyebrow">Reference Shelf</div>
      <h1>The Library</h1>
      <p class="kicker">Music theory for the realm. The principles and practices that govern Western music — scales, rhythm, keys, intervals, and chords — laid out chapter by chapter for study at your own pace.</p>
    </div>

    <section class="library-intro">
      <p>Music theory is the study of the principles and practices that govern music. It encompasses harmony, melody, rhythm, form, notation, and structure — a framework for understanding how music works, why certain combinations of sounds are pleasing to the ear, and how musicians create and interpret what they play.</p>
      <p>The chapters below cover the canon. Read them in order or pick whichever is most useful at hand.</p>
    </section>

    <section class="library-section">
      <h2>Contents</h2>
      <div class="chapter-grid">
        {chapters.map((c) => (
          <a class="chapter-card" href={c.href}>
            <div class="chapter-numeral">{c.numeral}</div>
            <div class="chapter-body">
              <span class="chapter-title">{c.title}</span>
              <p class="chapter-summary">{c.summary}</p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="library-section contributed-section">
      <h2>Contributed Materials</h2>
      <p class="contributed-intro">Beyond the canonical reference, the academy keeps a shelf for contributed materials — ABC and MIDI examples, drum charts, instrument guides, and other resources shared by faculty.</p>
      <div class="contributed-actions">
        <a class="btn btn-ghost" href="/library/contributed">Browse contributed materials →</a>
        {canContribute && (
          <a class="btn" href="/library/contributed/new">+ Add Content</a>
        )}
      </div>
    </section>
  </main>
</BaseLayout>

<style is:global>
  .library-intro {
    max-width: 760px;
    margin: 0 auto 16px;
    color: var(--ink-soft);
    font-size: 1.02rem;
    line-height: 1.7;
  }
  .library-intro p { margin: 0 0 1em; }

  .library-section { margin-top: 48px; }
  .library-section h2 {
    font-style: italic; font-weight: 500;
    margin-bottom: 16px;
    border-bottom: 1px double var(--rule-soft);
    padding-bottom: 8px;
  }

  .chapter-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  .chapter-card {
    display: flex;
    align-items: stretch;
    gap: 20px;
    padding: 22px 26px;
    background: linear-gradient(180deg, rgba(255,250,235,0.6), rgba(217,195,136,0.18));
    border: 1px solid var(--rule-soft);
    text-decoration: none; color: inherit;
  }
  .chapter-card:hover { border-color: var(--gold); }
  .chapter-numeral {
    font-family: var(--display);
    font-style: italic;
    font-size: 1.8rem;
    color: var(--gold);
    letter-spacing: 0.05em;
    line-height: 1;
    flex: 0 0 auto;
    padding-top: 4px;
  }
  .chapter-body { flex: 1; }
  .chapter-title {
    font-family: var(--display);
    font-size: 1.2rem;
    color: var(--forest-deep);
    font-weight: 600;
    display: block;
  }
  .chapter-summary {
    margin: 6px 0 0;
    color: var(--ink-soft);
    font-size: 0.95rem;
    line-height: 1.55;
  }

  .contributed-section { margin-top: 64px; }
  .contributed-intro {
    color: var(--ink-soft);
    max-width: 720px;
    line-height: 1.65;
  }
  .contributed-actions {
    display: flex;
    gap: 12px;
    align-items: center;
    margin-top: 16px;
    flex-wrap: wrap;
  }

  @media (max-width: 880px) {
    .chapter-grid { grid-template-columns: 1fr; }
  }
</style>
