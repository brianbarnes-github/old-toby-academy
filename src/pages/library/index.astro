---
import BaseLayout from '../../layouts/BaseLayout.astro';

export const prerender = false;

const supabase = Astro.locals.supabase;
const userId = Astro.locals.user?.id;
const canContribute = Astro.locals.permissions.has('library.contribute');

const { data: entries, error } = await supabase
  .from('library_entries')
  .select('id, slug, title, description, category, file_path, file_name, file_size, content_type, published_at, created_by, created_at')
  .order('category', { ascending: true })
  .order('title',    { ascending: true });

// RLS already filters drafts; this is just a safe fallback for ordering display.
const all = entries ?? [];
const myDrafts = all.filter((e: any) => e.published_at === null && e.created_by === userId);
const published = all.filter((e: any) => e.published_at !== null);
const otherDrafts = all.filter((e: any) => e.published_at === null && e.created_by !== userId);

// Group published entries by category
const byCategory = new Map<string, any[]>();
for (const e of published) {
  const key = e.category?.trim() || 'Uncategorized';
  if (!byCategory.has(key)) byCategory.set(key, []);
  byCategory.get(key)!.push(e);
}
const sortedCategories = [...byCategory.keys()].sort((a, b) =>
  a === 'Uncategorized' ? 1 : b === 'Uncategorized' ? -1 : a.localeCompare(b)
);

function publicUrl(path: string): string {
  return supabase.storage.from('library-files').getPublicUrl(path).data.publicUrl;
}

function fmtSize(bytes: number | null): string {
  if (!bytes) return '';
  if (bytes < 1024) return `${bytes} B`;
  if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`;
  return `${(bytes / (1024 * 1024)).toFixed(1)} MB`;
}

const ok = Astro.url.searchParams.get('ok');
const error_ = Astro.url.searchParams.get('error');
---

<BaseLayout
  title="The Library · Old Toby Academy"
  description="Reference materials and music-theory resources."
  activeNav="library"
  footerVariant="short"
>
  <main class="page">
    <div class="page-head">
      <div class="eyebrow">Reference Shelf</div>
      <h1>The Library</h1>
      <p class="kicker">Music theory, ABC and MIDI examples, drum charts, instrument guides — the canon of the academy. Browse, download, and study at your own pace.</p>
      {canContribute && (
        <p style="margin-top: 16px;">
          <a class="btn" href="/library/new">+ Add to the Library</a>
        </p>
      )}
    </div>

    {ok === 'deleted' && <div class="auth-ok">Entry deleted.</div>}
    {error_           && <div class="auth-err">{error_}</div>}
    {error            && <div class="auth-err">Could not load Library: {error.message}</div>}

    {canContribute && myDrafts.length > 0 && (
      <section class="library-section">
        <h2>Your drafts</h2>
        <div class="library-grid">
          {myDrafts.map((e: any) => (
            <a class="library-card library-card-draft" href={`/library/${e.slug}/edit`}>
              <div class="library-card-head">
                <span class="library-card-title">{e.title}</span>
                <span class="course-status-chip course-status-draft">draft</span>
              </div>
              <p class="library-card-meta">{e.file_name} · {fmtSize(e.file_size)}</p>
              {e.description && <p class="library-card-desc">{e.description}</p>}
            </a>
          ))}
        </div>
      </section>
    )}

    {sortedCategories.length === 0 ? (
      <p class="muted italic" style="margin-top: 32px;">The Library is empty.{canContribute && <> <a href="/library/new">Add the first entry</a>.</>}</p>
    ) : (
      sortedCategories.map((cat) => (
        <section class="library-section">
          <h2>{cat}</h2>
          <div class="library-grid">
            {byCategory.get(cat)!.map((e: any) => (
              <article class="library-card">
                <div class="library-card-head">
                  <span class="library-card-title">{e.title}</span>
                </div>
                <p class="library-card-meta">{e.file_name} · {fmtSize(e.file_size)}</p>
                {e.description && <p class="library-card-desc">{e.description}</p>}
                <div class="library-card-actions">
                  <a class="btn btn-ghost" href={publicUrl(e.file_path)} download={e.file_name} target="_blank" rel="noopener noreferrer">Download</a>
                  {(canContribute || e.created_by === userId) && (
                    <a class="row-action" href={`/library/${e.slug}/edit`}>Edit</a>
                  )}
                </div>
              </article>
            ))}
          </div>
        </section>
      ))
    )}

    {otherDrafts.length > 0 && (
      <section class="library-section">
        <h2>Other drafts</h2>
        <p class="muted italic">As headmaster, you can see drafts from other contributors.</p>
        <div class="library-grid">
          {otherDrafts.map((e: any) => (
            <a class="library-card library-card-draft" href={`/library/${e.slug}/edit`}>
              <div class="library-card-head">
                <span class="library-card-title">{e.title}</span>
                <span class="course-status-chip course-status-draft">draft</span>
              </div>
              <p class="library-card-meta">{e.file_name} · {fmtSize(e.file_size)}</p>
            </a>
          ))}
        </div>
      </section>
    )}
  </main>
</BaseLayout>

<style is:global>
  .library-section { margin-top: 48px; }
  .library-section h2 {
    font-style: italic; font-weight: 500;
    margin-bottom: 16px;
    border-bottom: 1px double var(--rule-soft);
    padding-bottom: 8px;
  }
  .library-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  .library-card {
    display: block;
    padding: 22px 26px;
    background: linear-gradient(180deg, rgba(255,250,235,0.6), rgba(217,195,136,0.18));
    border: 1px solid var(--rule-soft);
    text-decoration: none; color: inherit;
    border-bottom: 1px solid var(--rule-soft);
  }
  .library-card-draft { background: rgba(255, 250, 235, 0.3); }
  a.library-card:hover { border-color: var(--gold); }
  .library-card-head {
    display: flex; align-items: baseline; gap: 12px; flex-wrap: wrap;
    margin-bottom: 4px;
  }
  .library-card-title {
    font-family: var(--display);
    font-size: 1.2rem;
    color: var(--forest-deep);
    font-weight: 600;
  }
  .library-card-meta {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--ink-soft);
    margin: 0 0 8px;
    letter-spacing: 0.05em;
  }
  .library-card-desc { margin: 0 0 12px; font-size: 0.95rem; color: var(--ink-soft); }
  .library-card-actions { display: flex; gap: 12px; align-items: center; }

  @media (max-width: 880px) {
    .library-grid { grid-template-columns: 1fr; }
  }
</style>
