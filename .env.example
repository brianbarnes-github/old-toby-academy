# Copy this file to .env and fill in your Supabase credentials.
# Find these in: Supabase dashboard → Project Settings → API Keys
#
# Both values are safe in browsers (the publishable/anon key is meant for client use).
# DO NOT put the service_role / secret key here.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
